{
  "name": "@whatworks/analytics",
  "version": "2.1.1",
  "description": "Analytics components for Next.js with cookie consent.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api/consent": {
      "types": "./src/api/consent.ts",
      "import": "./src/api/consent.ts",
      "default": "./src/api/consent.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && pnpm build:css",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/styles.css -o ./dist/styles.css --minify",
    "check:exports": "publint && node ../../scripts/check-package-exports.mjs",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "dev": "next dev dev",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@whatworks/dev-fixture": "workspace:*",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "next": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "sort-package-json": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": ">=13.4.0 <17",
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/what-works-global/payload-packages",
    "directory": "packages/analytics"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./api/consent": {
        "types": "./dist/api/consent.d.ts",
        "import": "./dist/api/consent.js",
        "default": "./dist/api/consent.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {}
}
