{
  "name": "@whatworks/analytics",
  "version": "3.3.0",
  "description": "Analytics components for Next.js with cookie consent.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./google": {
      "types": "./src/entries/google.ts",
      "import": "./src/entries/google.ts",
      "default": "./src/entries/google.ts"
    },
    "./linkedin": {
      "types": "./src/entries/linkedin.ts",
      "import": "./src/entries/linkedin.ts",
      "default": "./src/entries/linkedin.ts"
    },
    "./clarity": {
      "types": "./src/entries/clarity.ts",
      "import": "./src/entries/clarity.ts",
      "default": "./src/entries/clarity.ts"
    },
    "./facebook": {
      "types": "./src/entries/facebook.ts",
      "import": "./src/entries/facebook.ts",
      "default": "./src/entries/facebook.ts"
    },
    "./posthog": {
      "types": "./src/entries/posthog.ts",
      "import": "./src/entries/posthog.ts",
      "default": "./src/entries/posthog.ts"
    },
    "./api/consent": {
      "types": "./src/api/consent.ts",
      "import": "./src/api/consent.ts",
      "default": "./src/api/consent.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "check:exports": "publint && node ../../scripts/check-package-exports.mjs",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "dev": "next dev dev",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepublishOnly": "node ../../scripts/guard-publish.mjs && pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@whatworks/dev-fixture": "workspace:*",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "next": "catalog:",
    "posthog-js": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "sort-package-json": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": ">=13.4.0 <17",
    "posthog-js": ">=1.0.0",
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "peerDependenciesMeta": {
    "posthog-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/what-works-global/payload-packages",
    "directory": "packages/analytics"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./google": {
        "types": "./dist/entries/google.d.ts",
        "import": "./dist/entries/google.js",
        "default": "./dist/entries/google.js"
      },
      "./linkedin": {
        "types": "./dist/entries/linkedin.d.ts",
        "import": "./dist/entries/linkedin.js",
        "default": "./dist/entries/linkedin.js"
      },
      "./clarity": {
        "types": "./dist/entries/clarity.d.ts",
        "import": "./dist/entries/clarity.js",
        "default": "./dist/entries/clarity.js"
      },
      "./facebook": {
        "types": "./dist/entries/facebook.d.ts",
        "import": "./dist/entries/facebook.js",
        "default": "./dist/entries/facebook.js"
      },
      "./posthog": {
        "types": "./dist/entries/posthog.d.ts",
        "import": "./dist/entries/posthog.js",
        "default": "./dist/entries/posthog.js"
      },
      "./api/consent": {
        "types": "./dist/api/consent.d.ts",
        "import": "./dist/api/consent.js",
        "default": "./dist/api/consent.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {}
}
