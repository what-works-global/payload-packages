{
  "name": "@whatworks/analytics",
  "version": "1.0.3",
  "description": "Analytics components for Next.js with cookie consent.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api/consent": {
      "import": "./src/api/consent.ts",
      "types": "./src/api/consent.ts",
      "default": "./src/api/consent.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:css && pnpm build:types && pnpm build:swc",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json,md}\" dist/",
    "dev": "next dev dev",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@swc-node/register": "catalog:",
    "@swc/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "copyfiles": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "next": "catalog:",
    "prettier": "catalog:",
    "postcss": "catalog:",
    "autoprefixer": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "sort-package-json": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "peerDependencies": {
    "next": ">=13.4.0 <16",
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./api/consent": {
        "import": "./dist/api/consent.js",
        "types": "./dist/api/consent.d.ts",
        "default": "./dist/api/consent.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {}
}
