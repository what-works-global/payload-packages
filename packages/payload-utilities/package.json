{
  "name": "@whatworks/payload-utilities",
  "version": "2.0.1",
  "description": "A collection of utilities for Payload 3.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./traverseDocument": {
      "import": "./src/traverseDocument/index.ts",
      "types": "./src/traverseDocument/index.ts",
      "default": "./src/traverseDocument/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "lint": "eslint ./src ./dev --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint ./src ./dev --ext .ts,.tsx,.js,.mjs --fix",
    "prepublishOnly": "pnpm clean && pnpm build",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@playwright/test": "^1.52.0",
    "@swc-node/register": "catalog:",
    "@swc/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "copyfiles": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "graphql": "^16.8.1",
    "mongodb-memory-server": "10.1.4",
    "next": "catalog:",
    "open": "^10.1.0",
    "prettier": "catalog:",
    "qs-esm": "7.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "sharp": "catalog:",
    "sort-package-json": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./traverseDocument": {
        "import": "./dist/traverseDocument/index.js",
        "types": "./dist/traverseDocument/index.d.ts",
        "default": "./dist/traverseDocument/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {}
}
