{
  "name": "@whatworks/payload-utilities",
  "version": "3.0.0",
  "description": "A collection of utilities for Payload 3.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./traverseDocument": {
      "types": "./src/traverseDocument/index.ts",
      "import": "./src/traverseDocument/index.ts",
      "default": "./src/traverseDocument/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check:exports": "publint && node ../../scripts/check-package-exports.mjs",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cd dev && cross-env PAYLOAD_CONFIG_PATH=./payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepublishOnly": "pnpm build",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest run dev/int.spec.ts",
    "test:peer": "vitest run test/peer.smoke.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "@payloadcms/db-mongodb": "catalog:",
    "@payloadcms/richtext-lexical": "catalog:",
    "@payloadcms/translations": "catalog:",
    "@playwright/test": "^1.52.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@whatworks/dev-fixture": "workspace:*",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "graphql": "^16.8.1",
    "mongodb-memory-server": "10.1.4",
    "next": "catalog:",
    "open": "^10.1.0",
    "payload": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "qs-esm": "7.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "sharp": "catalog:",
    "sort-package-json": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": ">=3.29.0 <4",
    "@payloadcms/translations": ">=3.29.0 <4",
    "payload": ">=3.29.0 <4"
  },
  "whatworks": {
    "peerMatrix": {
      "payload": {
        "min": "3.29.0"
      }
    }
  },
  "dependencies": {
    "@payloadcms/ui": "catalog:"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/what-works-global/payload-packages",
    "directory": "packages/payload-utilities"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./traverseDocument": {
        "types": "./dist/traverseDocument/index.d.ts",
        "import": "./dist/traverseDocument/index.js",
        "default": "./dist/traverseDocument/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "registry": "https://registry.npmjs.org/"
}
