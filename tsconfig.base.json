{
  "compilerOptions": {
    "allowJs": true,
    "composite": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "plugins": [{ "name": "next" }],
    "resolveJsonModule": true,
    "rootDir": "./",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "emitDeclarationOnly": true
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/test/**/*.ts",
    "${configDir}/tsdown.config.ts",
    "${configDir}/vitest.config.ts",
    "${configDir}/vitest.config.js",
    "${configDir}/playwright.config.js"
  ]
}
